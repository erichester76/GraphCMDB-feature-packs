{
    "Organization": {
        "display_name": "Organization",
        "description": "A unit within an organizational hierarchy (company, department, team, etc.)",
        "category": "Organizational",
        "properties": [
            "name",
            "description",
            "organization_id",
            "industry",
            "website",
            "phone_number",
            "created_date",
            "updated_date",
            {"name": "type", "choices": ["company", "department", "customer", "vendor"]},
            {"name": "status", "choices": ["active", "inactive"]}
        ],
        "required": ["name"],
        "columns": ["name", "parent"],
        "relationships": {
            "CHILD_OF": {
                "target": "Organization",
                "direction": "out",
                "description": "Parent organization relationship"
            },
            "LOCATED_AT": {
                "target": "Location",
                "direction": "out",
                "description": "Organization is located at Location"
            },
            "HAS_MEMBER": {
                "target": "Person, Group",
                "direction": "out",
                "description": "Organization has members (people or groups)"
            },
            "OWNS": {
                "target": "Location, Group, Role",
                "direction": "out",
                "description": "Organization owns locations, groups, or roles"
            }
        }
    },
    "Location": {
        "display_name": "Location",
        "description": "A physical or logical location, can be nested.",
        "category": "Organizational",
        "properties": [
            "name",
            "address",
            "description",
            "gps_coordinates",
            "facility_id",
            "created_date",
            "updated_date",
            {"name": "type", "choices": ["site", "building", "floor", "room"]},
            {"name": "status", "choices": ["active", "inactive"]}
            
        ],
        "required": ["name"],
        "columns": ["name", "parent"],
        "relationships": {
            "CHILD_OF": {
                "target": "Location",
                "direction": "out", 
                "description": "Parent location relationship"
            },
            "USED_BY": {
                "target": "Group, Organization, Person",
                "direction": "out",
                "description": "Used by Group, Organization, or Person"
            },
            "CONTAINS": {
                "target": "Location, Organization, Group",
                "direction": "out",
                "description": "Location contains other locations, organizations, or groups"
            }
        }
    },
    "Person": {
        "display_name": "Person",
        "description": "An individual in the organization.",
        "category": "Organizational",
        "properties": [
            "name",
            "email",
            "person_id",
            "title",
            "phone_number",
            "created_date",
            "updated_date",
            "start_date",
            "end_date",
            {"name": "status", "choices": ["active", "inactive"]}
        ],
        "required": ["name"],
        "columns": ["name", "email"],
        "relationships": {
            "LOCATED_AT": {
                "target": "Location",
                "direction": "out",  
                "description": "Person is located at Location"
            },
            "REPORTS_TO": {
                "target": "Person",
                "direction": "out",  
                "description": "Manager relationship"
            },
            "MEMBER_OF": {
                "target": "Group, Organization",
                "direction": "out",  
                "description": "Group or organization membership"
            },
            "PERFORMS": {
                "target": "Role",
                "direction": "out",
                "description": "A job title or responsibility"
            },
            "PARTICIPATES_IN": {
                "target": "Group",
                "direction": "out",
                "description": "Person participates in group activities"
            }
        }
    },
    "Group": {
        "display_name": "Group",
        "description": "A non-hierarchical collection of people (e.g., committee, working group).",
        "category": "Organizational",
        "properties": [
            "name",
            "group_id",
            "description",
            "created_date",
            "updated_date",
            {"name": "type", "choices": ["department", "comittee", "project"]},
            {"name": "status", "choices": ["active", "inactive"]}
        ],
        "required": ["name"],
        "columns": ["name"],
        "relationships": {
            "HAS_MEMBER": {
                "target": "Person, Organization",
                "direction": "out",
                "description": "Group has members (people or organizations)"
            },
            "ASSOCIATED_WITH": {
                "target": "Location, Role",
                "direction": "out",
                "description": "Group is associated with locations or roles"
            }
        }
    },
    "Role": {
        "display_name": "Role",
        "description": "A job title or responsibility, assignable to people or organizations.",
        "category": "Organizational",
        "properties": [
            "name",
            "role_id",
            "description",
            "created_date",
            "updated_date",
            {"name": "status", "choices": ["active", "inactive"]}
        ],
        "required": ["name"],
        "columns": ["name"],
        "relationships": {
            "ASSIGNED_TO": {
                "target": "Person, Organization, Group",
                "direction": "in",
                "description": "Role is assigned to person, organization, or group"
            }
        }
    }
}
