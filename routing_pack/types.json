{
  "AutonomousSystem": {
    "display_name": "Autonomous System",
    "category": "Routing",
    "properties": [
      "asn",
      "asn_type",
      "organization_name",
      "registry",
      "irr_as_set",
      "description",
      "peering_policy_url",
      "noc_email",
      "registration_date"
    ],
    "required": ["asn"],
    "relationships": {
      "MEMBER_OF_CONFEDERATION": {
        "target": "AutonomousSystem",
        "direction": "out",
        "description": "Confederation member AS → confederation AS (for confederations)"
      }
    }
  },

  "BGPPeer": {
    "display_name": "BGP Peer",
    "category": "Routing",
    "properties": [
      "name",
      "peer_ip",
      "peer_ipv6",
      "description",
      "peer_type",
      "multihop",
      "password_set"
    ],
    "required": ["name", "peer_ip"],
    "relationships": {
      "MEMBER_OF": {
        "target": "VRF",
        "direction": "out"
      },
      "PEER_ON_INTERFACE": {
        "target": "Interface",
        "direction": "out"
      },
      "APPLIES_POLICY_IN": {
        "target": "RoutingPolicy",
        "direction": "out"
      },
      "APPLIES_POLICY_OUT": {
        "target": "RoutingPolicy",
        "direction": "out"
      },
      "PEERS_WITH": {
        "target": "AutonomousSystem",
        "direction": "out",
        "cardinality": "1",
        "description": "The remote Autonomous System this peer belongs to"
      },
      "PEERS_FROM": {
        "target": "AutonomousSystem",
        "direction": "out",
        "cardinality": "1",
        "description": "The local Autonomous System this peer belongs to"
      }
    }
  },

  "BGPProcess": {
    "display_name": "BGP Process",
    "category": "Routing",
    "properties": [
      "name",
      "router_id",
      "description",
      "cluster_id",
      "confederation_id"
    ],
    "required": ["name"],
    "relationships": {
      "RUNS_ON": {
        "target": "Device",
        "direction": "out"
      },
      "MEMBER_OF": {
        "target": "VRF",
        "direction": "out"
      },
      "HAS_LOCAL_AS": {
        "target": "AutonomousSystem",
        "direction": "out",
        "cardinality": "1",
        "description": "The local Autonomous System this BGP process is configured with"
      }
    }
  },

